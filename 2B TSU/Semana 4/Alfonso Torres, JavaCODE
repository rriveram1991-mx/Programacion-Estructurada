package javaapplication37;

import java.util.Scanner;

/**
 *
 * @author fonso
 */


public class SistemaControlNotas {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int opcion = 0;
        int total = 0;
        int cantidad = 0;
        //error logico y de compilación al colocar una variable booleana, esto impide que pase más alla de "SISTEMA DE CONTROL DE NOTAS"

        System.out.println("=== SISTEMA DE CONTROL DE NOTAS ===");

        while (opcion != 5) {

            System.out.println("1. Capturar notas"); //Error de sintaxis al llevar /n
            System.out.println("2. Mostrar promedio");
            System.out.println("3. Mostrar estadisticas");
            System.out.println("4. Reiniciar datos");
            System.out.println("5. Salir");

            System.out.print("Seleccione opcion: ");
            opcion = sc.nextInt();

            switch (opcion) {

                case 1:

                    System.out.print("Cuantas notas desea capturar: ");
                    int n = sc.nextInt();

                    for (int i = 1; i <= n; i++) {
//erro logico, el llevar un 0 para 1, esta mal,puesto que no captura la cantidad deseada.
                        System.out.print("Ingrese nota #" + i + ": ");
                        int nota = sc.nextInt();

                        if (nota >= 0 && nota <= 10) //error: mala practica: al poner un punto y coma que impide continuar el programa.
                        {
                            total += nota;
                            cantidad++;} //erro de sintaxis: no llevaba corchetes que abrieran y cerrarán el calculo para proseguir.
                    
                            else {
                            System.out.println("Nota invalida");
                                    }
                    }
                    break; //Error: mala practica, al no tener un break no cierra el caso.
                case 2:

                    double promedio = (total/cantidad);
                    System.out.println("Promedio: " + promedio);

                    if (promedio >= 9)
                        System.out.println("Excelente");
                    else if (promedio >= 8)
                        System.out.println("Bueno");
                    else if (promedio >= 7) //Error logico y mala practica. Llevaba un punto y coma donde no debería.
                        System.out.println("Regular");
                        else {
                        System.out.println("Reprobado");
                                }
                    break;

                case 3:

                    int aprobados = 0;
                    int reprobados = 0;

                    int i = 0;
                    while (i < cantidad) { //Error: mala practica, poniendo un punto y coma
                        if ((total / cantidad) >= 7) {
                            aprobados++;
                            i++; //Error de compilación: Al no agregar i++, la variable i no suma a los aprobados. Además, ocurría un error que impedía continuar si daba >7
                        }
                        else {
                            reprobados++;
                        i++;
                    
                        } //erro de sintaxis, no colocar un corchete "{}" que termine el "else"
                    }

                    System.out.println("Aprobados: " + aprobados);
                    System.out.println("Reprobados: " + reprobados);
                    break;

                case 4:

                    total = 0;
                    cantidad = 0;
                    System.out.println("Datos reiniciados");
                    break; 

                case 5:

                    opcion = 5;
                    System.out.println("Saliendo del sistema");
                    break; //Mala practica, al no poner break en caso 4 y 5, el programa no sale de estos.

                default:
                    System.out.println("Opcion no valida");
            }

        }

        sc.close();
    }
}
    
