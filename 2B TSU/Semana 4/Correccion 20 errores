package javaapplication0.pkg2;
import java.util.ArrayList;// corrección 1: Se importa ArrayList para poder almacenar y recuperar notas individualmente
import java.util.Scanner;

/**
 *
 * @author adrianvalenzuelaramirez
 */
public class JavaApplication02 {

    /**
     * @param args the command line arguments
     */
        
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        // Correccion 2: Se crea una lista dinámica para evitar que las notas se pierdan al capturar la siguiente
        ArrayList<Double> listaNotas = new ArrayList<>(); 
        
        int opcion = 0;
        boolean salir = false;

        System.out.println("=== SISTEMA DE CONTROL DE NOTAS ===");

        // Correccion 3: Se cambió '=' por '!' para que el bucle evalúe el valor booleano y no asigne "false"
        while (!salir) { 

            System.out.println("\n1. Capturar notas");
            System.out.println("2. Mostrar promedio");
            System.out.println("3. Mostrar estadisticas");
            System.out.println("4. Reiniciar datos");
            System.out.println("5. Salir");

            System.out.print("Seleccione opcion: ");
            opcion = sc.nextInt(); 

            switch (opcion) {

                case 1:
                    System.out.print("Cuantas notas desea capturar: ");
                    int n = sc.nextInt();

                    // Correccion 4: Se eliminó el '<=' para evitar que pida una nota extra (error de desfase)
                    // Corrección 5: Se inicializa 'i' en 0 pero se muestra (i+1) para mejor lectura del usuario
                    for (int i = 0; i < n; i++) {

                        System.out.print("Ingrese nota #" + (i + 1) + ": ");
                        double nota = sc.nextDouble(); // CORRECCIÓN 6: Se cambió a 'double' para aceptar decimales

                        // Correccion 7: Se eliminó el ';' después del IF que anulaba la validación
                        // Corrección 8: Se agregaron llaves '{}' para agrupar las instrucciones del IF
                        if (nota >= 0 && nota <= 10) {
                            listaNotas.add(nota); // Correccion 9: Se usa .add() para guardar la nota en memoria
                        } 
                        // Corrección 10: El 'else' ya no está huérfano y funciona correctamente
                        else {
                            System.out.println("Nota invalida");
                            i--; // Correccion 11: Se resta 1 al índice para repetir la captura de la nota fallida
                        }
                    }
                    break; // Correccion 12: Se agregó 'break' para evitar que entre al case 2 por error

                case 2:
                    // Corrección 13: Se añadió validación para evitar error de división por cero si no hay notas
                    if (listaNotas.isEmpty()) {
                        System.out.println("Error: No hay notas registradas.");
                    } else {
                        double suma = 0;
                        for (double nt : listaNotas) suma += nt; 
                        
                        // Correccion 14: Se eliminó la división de enteros (int/int) para no perder decimales
                        double promedio = suma / listaNotas.size(); 
                        System.out.println("Promedio: " + promedio);

                        if (promedio >= 9)
                            System.out.println("Excelente");
                        else if (promedio >= 8)
                            System.out.println("Bueno");
                        // Correccion 15: Se eliminó el ';' que hacía que "Regular" se imprimiera siempre
                        else if (promedio >= 7)
                            System.out.println("Regular");
                        // Corrección 16: El 'else' final ahora sí pertenece a la cadena de condiciones
                        else
                            System.out.println("Reprobado");
                    }
                    break;

                case 3:
                    int aprobados = 0;
                    int reprobados = 0;

                    // Correccion 17: Se eliminó el ';' del while que causaba un bucle infinito
                    // Corrección 18: Se cambió la lógica para evaluar CADA nota de la lista, no el promedio total
                    for (double notaIndividual : listaNotas) { 
                        if (notaIndividual >= 7)
                            aprobados++;
                        else
                            reprobados++;
                    }

                    System.out.println("Aprobados: " + aprobados);
                    System.out.println("Reprobados: " + reprobados);
                    break;

                case 4:
                    listaNotas.clear(); // Correcion 19: Se limpian los datos de la lista correctamente
                    System.out.println("Datos reiniciados");
                    break; // Corrección 20: Se agregó 'break' para que no se salga del sistema después de reiniciar

                case 5:
                    salir = true;
                    System.out.println("Saliendo del sistema");
                    break;

                default:
                    System.out.println("Opcion no valida");
            }
        }
        sc.close();
    }
}
    
