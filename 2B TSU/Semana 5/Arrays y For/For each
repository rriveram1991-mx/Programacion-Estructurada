package javaapplication42;

import java.util.Scanner;

/**
 *
 * @author ssjoa
 */
public class JavaApplication42 {

    /**
     * @param args the command line arguments
     */
    public static void main(String[] args)
    {
        Scanner leer = new Scanner(System.in);
       int [] archivero = new int [4];
       
       for (int x = 0; x < archivero.length; x++)
       {
           System.out.println("Dame la cantidad de documentos en el archivero "+(x+1)+ ":");
           archivero[x]=leer.nextInt();
           
       }
       int mayor = archivero[0];
       for(int expediente : archivero)
       {
           if(expediente>mayor)
           {
               mayor =expediente;
           }
       }
        System.out.println("El Archivero con mas documentos tiene: "+mayor+" documentos");
        
    
}
}
