package detecion.error;

import java.util.Scanner;

/**
 *
 * @author brand
 */
public class DetecionError {

    /**
     * @param args the command line arguments
     */
    public static void main(String[] args) {
        // TODO code application logic here
    Scanner sc = new Scanner(System.in);

        int opcion = 0;
        double total = 0; //Debe ser double para la division ERROR LOGICO
         int[] notas = new int[20]; //Un arreglo para poder guardar los datos de las notas ya que en el case 3 no se ejecuta como
                                    // deberia, solo muestra reprobados o aprobados, pero no ambos.
        int cantidad = 0;
        boolean salir = false;

        System.out.println("=== SISTEMA DE CONTROL DE NOTAS ===");

        while (salir==false) { //(salir=false), esta asignando, no comparando, por eso no funciona ERROR DE COMPILACION y ERROR LOGICO

            System.out.println("\n1. Capturar notas");
            System.out.println("2. Mostrar promedio");
            System.out.println("3. Mostrar estadisticas");
            System.out.println("4. Reiniciar datos");
            System.out.println("5. Salir");

            System.out.print("Seleccione opcion: ");
            opcion = sc.nextInt();

            switch (opcion) {

                case 1:

                    System.out.print("Cuantas notas desea capturar: ");
                    int n = sc.nextInt();
                        if (n <= 0) { //Falto este if para cuando se ingrese un numero negativo, que mande el error ERROR LOGICO
                             System.out.println("Cantidad invalida. Debe ser mayor a 0.");
                             break;
                         }
                    for (int i = 1; i <= n; i++) { //la i debe ser igual a 1 ya que empieza a contar desde el 0 ERROR LOGICO
                        if (cantidad >= 20) { //El limite de notas que pusimos en el arreglo
                            System.out.println("Limite de notas alcanzado");
                        break; }//Break para dejar de ejecutar el if si no hay datos ERROR LOGICO
                        
                        System.out.print("Ingrese nota #" + i + ": ");
                        int nota = sc.nextInt();
                       
                        if (nota >= 0 && nota <= 10){ //Punto y coma no va, va llave para abrir el If ERROR DE COMPILACION y MALA PRACTICA
                            notas[cantidad]=nota; //Aqui se guardaran los datos de las notas
                            total+=nota;
                            cantidad++; 
                        }
                        else{
                            System.out.println("Nota invalida");} //Faltan las llaves del else MALA PRACTICA
                        } 
                    
                    break; //Aqui falto el Break ERROR LOGICO
                    

                case 2:
                      if (cantidad==0){ //Falta este If para que cuando se ingrese esta opcion sin capturar notas enseñe este mensaje
                                        //y no se cierre automaticamente por el error ERROR DE COMPILACION
                          System.out.println("No hay notas registradas");
                       break;}  //Break para dejar de ejecutar el if si no hay datos ERROR LOGICO 
                    double promedio = total / cantidad;
                    System.out.println("Promedio: " + promedio);

                    if (promedio >= 9){  // Falta la llave para abrir el IF MALA PRACTICA
                        System.out.println("Excelente");}
                    else if (promedio >= 8){ //Faltan las llaves del else MALA PRACTICA
                        System.out.println("Bueno");}
                    else if (promedio >= 7){ //Punto y coma no va ahi, va la llave para abrir el elseif ERROR DE COMPILACION
                        System.out.println("Regular");}
                    else{
                        System.out.println("Reprobado");} //Faltan las llaves del else MALA PRACTICA

                    break;

                case 3:
                    if (cantidad == 0) {
                        System.out.println("No hay datos para estadisticas"); //Indicar que no hay nada que mostar si antes no se
                                                                               // ingresaron Datos ERROR DE COMPILACION
                   break; //Break para dejar de ejecutar el if si no hay datos ERROR LOGICO 
                    }
                    int aprobados = 0;
                    int reprobados = 0;

                    int i = 0;

                    while (i < cantidad) {

                        if (notas[i] >= 7) { //Un IF para mostrar correctamente cuantos alumnos estan aprobados y cuantos reprobados
                                             //con ayuda de un arreglo ERROR DE COMPILACION
                            aprobados++;
                        } else {
                            reprobados++;
                        }
                        i++;
                    }
                    System.out.println("Aprobados: " + aprobados);
                    System.out.println("Reprobados: " + reprobados);

                    break;

                case 4:
                    total = 0;
                    cantidad = 0;
                    System.out.println("Datos reiniciados");
                     break; //Falto el Break ERROR LOGICO
                case 5:

                    salir = true;
                    System.out.println("Saliendo del sistema");
                    break; //Falto el Break ERROR LOGICO
                default:
                    System.out.println("Opcion no valida");
            }

        }

        sc.close();
    }
}
